[
    {
        "caption": "Preferences",
        "mnemonic": "n",
        "id": "preferences",
        "children": [
            {
                "caption": "Package Settings",
                "mnemonic": "P",
                "id": "package-settings",
                "children": [
                    {
                        "caption": "TermMate",
                        "children": [
                            {
                                "command": "edit_settings",
                                "args": {
                                    "base_file": "${packages}/TermMate/TermMate.sublime-settings",
                                    "default": "{\n\t\"claude_command\": \"\"\n}\n"
                                },
                                "caption": "Settings"
                            },
                            {
                                "caption": "-"
                            },
                            {
                                "caption": "Key Bindings",
                                "command": "edit_settings",
                                "args": {
                                    "base_file": "${packages}/TermMate/Default.sublime-keymap",
                                    "default": "[\n\t{ \"keys\": [\"primary+alt+g\"], \"command\": \"chat_view_cli\" }\n]\n"
                                }
                            }
                        ]
                    }
                ]
            }
        ]
    }
]
