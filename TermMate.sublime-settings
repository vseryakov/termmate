{
    // Sets the logging level.
    // Valid values are "DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL".
    "log_level": "ERROR",

    // List of tools to use without confirmation.
    "allowed_tools": ["Read", "Glob", "Grep", "TodoWrite", "WebFetch", "WebSearch", "Skill"],

    // List of tools to completely disable for the agents.
    "disable_ask_user": true,

    // Whether to share all open workspace folders with the agent.
    // If true, the agent can access files in all folders currently open in the workspace.
    // If false, the agent only has access to the agent working directory(cwd).
    "share_workspace_folders": true,

    // Path or command name for the coding CLI executable.
    "claude_command": "",
    "codex_command": "",
    "pi_command": "",

    // Extra environment variables to inject into Claude and Codex subprocesses.
    // Useful for setting API keys, or any other per-user env configuration.
    // Example:
    // "env": {
    //   "ANTHROPIC_API_KEY": "sk-ant-...",
    //   "CODEX_API_KEY": "sk-..."
    // }
    "env": {}
}
